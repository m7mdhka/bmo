# Ignore VCS
.git
.gitignore

# OS/editor files
**/.DS_Store
**/.idea
**/.vscode

# Python caches/venvs
**/__pycache__/
**/*.pyc
**/.venv/
**/venv/

# Node deps/build output
**/node_modules/
**/.next/
**/dist/
**/build/

# Logs
**/*.log

# Env/secrets
**/.env
**/.env.*

# Coverage/test outputs
**/.pytest_cache/
**/.coverage
**/htmlcov/
**/coverage.xml

